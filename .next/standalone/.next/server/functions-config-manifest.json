{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!_next\\/static|_next\\/image|api\\/recommend|favicon.ico|sw.js|manifest.json|images\\/|icon-|apple-icon|robots.txt|sitemap.xml).*))(\\.json)?[\\/#\\?]?$",
