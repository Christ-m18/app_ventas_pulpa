      "regex": "^/admin/orders/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/orders/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
